@startuml
title Diagrama de Despliegue - Dashboard Electoral Perú 2021

skinparam dpi 200
skinparam defaultFontSize 13
skinparam linetype ortho

node "Usuario Final" {
  artifact "Navegador Web"
}

node "Equipo de Desarrollo" {
  artifact "Power BI Desktop"
  artifact "Archivos Excel/CSV"
  artifact "Scripts de limpieza\nPython/Excel"
}

node "Repositorio de Datos" {
  database "Dataset Electoral"
  database "Planes de Gobierno"
}

cloud "Servicio Web / Cloud" {
  node "Power BI Service" {
    artifact "Dashboard Publicado"
    artifact "Reportes Visuales"
  }
}

"Archivos Excel/CSV" --> "Dataset Electoral"
"Scripts de limpieza\nPython/Excel" --> "Dataset Electoral"
"Scripts de limpieza\nPython/Excel" --> "Planes de Gobierno"

"Dataset Electoral" --> "Power BI Desktop"
"Planes de Gobierno" --> "Power BI Desktop"

"Power BI Desktop" --> "Dashboard Publicado"
"Dashboard Publicado" --> "Navegador Web"
"Reportes Visuales" --> "Navegador Web"

@enduml